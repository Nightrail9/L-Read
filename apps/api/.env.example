OPENAI_API_KEY=replace_with_your_openai_key
MINERU_TOKEN=replace_with_your_mineru_token

# Startup settings (used by start.bat)
STARTUP_PYTHON_EXE=.\\env\\python.exe
STARTUP_APP_PORT=8000
STARTUP_OPEN_PATH=/task

MINERU_SKIP_SSL_VERIFY=false
MINERU_DOWNLOAD_RETRIES=3

FRONTEND_ORIGIN=http://127.0.0.1:5173
BACKEND_PORT=8000

# Default provider for analysis modules: gpt | gemini | openai-compatible
LLM_PROVIDER=gpt

# GPT provider (compatible with legacy OPENAI_* variables)
GPT_API_KEY=
GPT_BASE_URL=https://api.openai.com/v1
GPT_MODEL_TEXT=gpt-4.1-mini
GPT_MODEL_VISION=gpt-4.1-mini

# Gemini provider
GEMINI_API_KEY=replace_with_your_gemini_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL_TEXT=gemini-2.5-flash
GEMINI_MODEL_VISION=gemini-2.5-flash

# OpenAI-compatible provider
OPENAI_COMPAT_API_KEY=replace_with_your_openai_compat_key
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL_TEXT=gpt-4o-mini
OPENAI_COMPAT_MODEL_VISION=gpt-4o-mini

# Legacy aliases for GPT provider
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_TEXT=gpt-4.1-mini
OPENAI_MODEL_VISION=gpt-4.1-mini

MAX_GLOBAL_CONCURRENCY=3
MAX_JOB_CONCURRENCY=1
LLM_TIMEOUT_CONNECT_SEC=15
LLM_TIMEOUT_READ_SEC=600
LLM_RETRIES=3
LLM_RETRY_BACKOFF_SEC=2
LLM_MAX_OUTPUT_TOKENS=6000
LLM_CONTINUATION_ROUNDS=2
GIT_CLONE_RETRIES=3
GIT_CLONE_TIMEOUT_SEC=180
GIT_HTTP_PROXY=
GIT_HTTPS_PROXY=
GIT_SSL_NO_VERIFY=false
MAX_FILE_BYTES=5242880
MAX_TOTAL_BYTES=209715200
MAX_FILES=2000
